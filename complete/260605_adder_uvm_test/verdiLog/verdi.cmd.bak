simSetSimulator "-vcssv" -exec "./simv" -args
debImport "-dbdir" "./simv.daidir/"
debLoadSimResult /home/pedu14/wkp/260605_adder_uvm_test/wave.fsdb
wvCreateWindow
verdiSetActWin -win $_nWave2
verdiWindowResize -win $_Verdi_1 "830" "370" "900" "700"
verdiSetActWin -dock widgetDock_MTB_SOURCE_TAB_1
srcHBDrag -win $_nTrace1
verdiSetActWin -dock widgetDock_<Inst._Tree>
wvAddSignal -win $_nWave2 "tb_adder/dut/a\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/dut/b\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/dut/y\[8:0\]"
wvSetPosition -win $_nWave2 {("dut" 0)}
wvRenameGroup -win $_nWave2 {G1} {dut}
srcHBSelect "uvm_custom_install_recording" -win $_nTrace1
srcHBSelect "tb_adder.adder_if" -win $_nTrace1
srcHBDrag -win $_nTrace1
wvSetPosition -win $_nWave2 {("adder_if(adder_intf)" 0)}
wvRenameGroup -win $_nWave2 {dut} {adder_if(adder_intf)}
wvAddSignal -win $_nWave2 "tb_adder/adder_if/a\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/adder_if/b\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/adder_if/y\[8:0\]"
srcHBSelect "tb_adder" -win $_nTrace1
srcHBDrag -win $_nTrace1
wvSetPosition -win $_nWave2 {("tb_adder" 0)}
wvRenameGroup -win $_nWave2 {adder_if(adder_intf)} {tb_adder}
srcDeselectAll -win $_nTrace1
verdiSetActWin -dock widgetDock_MTB_SOURCE_TAB_1
verdiSetActWin -dock widgetDock_<Inst._Tree>
srcHBSelect "tb_adder.adder_if" -win $_nTrace1
srcHBDrag -win $_nTrace1
wvSetPosition -win $_nWave2 {("adder_if(adder_intf)" 0)}
wvRenameGroup -win $_nWave2 {tb_adder} {adder_if(adder_intf)}
wvAddSignal -win $_nWave2 "tb_adder/adder_if/a\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/adder_if/b\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/adder_if/y\[8:0\]"
wvUnknownSaveResult -win $_nWave2 -clear
srcHBSelect "tb_adder.dut" -win $_nTrace1
srcHBDrag -win $_nTrace1
wvAddSignal -win $_nWave2 "tb_adder/dut/a\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/dut/b\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/dut/y\[8:0\]"
wvSetPosition -win $_nWave2 {("dut" 0)}
wvRenameGroup -win $_nWave2 {adder_if(adder_intf)} {dut}
srcHBSelect "tb_adder.adder_if" -win $_nTrace1
srcHBDrag -win $_nTrace1
wvSetPosition -win $_nWave2 {("adder_if(adder_intf)" 0)}
wvRenameGroup -win $_nWave2 {dut} {adder_if(adder_intf)}
wvAddSignal -win $_nWave2 "tb_adder/adder_if/a\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/adder_if/b\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/adder_if/y\[8:0\]"
srcHBSelect "uvm_custom_install_recording" -win $_nTrace1
srcHBDrag -win $_nTrace1
wvSetPosition -win $_nWave2 {("uvm_custom_install_recording" 0)}
wvRenameGroup -win $_nWave2 {adder_if(adder_intf)} {uvm_custom_install_recording}
srcHBDrag -win $_nTrace1
wvSetPosition -win $_nWave2 {("tb_adder" 0)}
wvRenameGroup -win $_nWave2 {uvm_custom_install_recording} {tb_adder}
srcHBSelect "tb_adder.adder_if" -win $_nTrace1
srcHBSelect "tb_adder.dut" -win $_nTrace1
srcSetScope "tb_adder.dut" -delim "." -win $_nTrace1
srcHBDrag -win $_nTrace1
wvAddSignal -win $_nWave2 "tb_adder/dut/a\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/dut/b\[7:0\]"
wvAddSignal -win $_nWave2 "tb_adder/dut/y\[8:0\]"
wvSetPosition -win $_nWave2 {("dut" 0)}
wvRenameGroup -win $_nWave2 {tb_adder} {dut}
wvUnknownSaveResult -win $_nWave2 -file \
           /home/pedu14/wkp/260605_adder_uvm_test/unknownSignals.txt
debExit
